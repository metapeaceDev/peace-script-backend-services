# Peace Script Backend - Production Environment Variables
# Copy this file to .env.production and update with your values

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=production
API_TITLE="Peace Script - Digital Mind Model API"
API_VERSION="2.0.0"
API_DESCRIPTION="Digital Mind Model for Film Production with Buddhist Psychology"
DEBUG=false

# ============================================================================
# Database Configuration
# ============================================================================
# Option 1: MongoDB Atlas (Recommended)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=peace_script_production

# Option 2: Self-hosted MongoDB
# MONGO_URI=mongodb://peace_script_user:your_password@localhost:27017/peace_script_production

# ============================================================================
# Security Configuration
# ============================================================================
# Generate a new SECRET_KEY with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MINIMUM_32_CHARACTERS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================================
# CORS Configuration
# ============================================================================
# Update with your production domain(s)
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# ============================================================================
# Rate Limiting (Optional - Redis)
# ============================================================================
# If you want to use Redis for rate limiting instead of in-memory:
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=INFO

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# External Services (Optional)
# ============================================================================
# OpenAI API (if using AI features)
# OPENAI_API_KEY=sk-...

# Email Service (for password reset, verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ============================================================================
# Performance Tuning
# ============================================================================
# Number of Uvicorn workers (typically 2-4x CPU cores)
WORKERS=4

# Max request body size (in bytes, e.g., 50MB)
MAX_UPLOAD_SIZE=52428800
