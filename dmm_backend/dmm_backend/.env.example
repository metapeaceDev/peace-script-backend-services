API_KEY=YOUR_SECRET_API_KEY

# Mongo connection (use Docker mongo service or local instance)
MONGO_URI=mongodb://127.0.0.1:27017
# หรือใช้ MongoDB Atlas: mongodb+srv://<USER>:<PASS>@<cluster>.mongodb.net/digital_mind_model
MONGO_DB_NAME=digital_mind_model

# Comma-separated CORS origins (include every frontend host/port)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional logging level (debug|info|warning|error|critical)
LOG_LEVEL=info

# Toggle Prometheus metrics endpoint (true/false)
ENABLE_METRICS=true

# ======================================================================
# Phase 2: Authentication & Security Configuration
# ======================================================================

# CRITICAL: SECRET_KEY is REQUIRED for JWT token signing
# Generate a secure random key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit your actual SECRET_KEY to git!
# NEVER use default or example values in production!
SECRET_KEY=GENERATE_YOUR_OWN_SECRET_KEY_HERE

# JWT Configuration
JWT_ALGORITHM=HS256                 # JWT signing algorithm
JWT_EXPIRATION_HOURS=1              # Token lifetime in hours

# Password Hashing Configuration
BCRYPT_ROUNDS=12                    # Bcrypt hashing rounds (higher = more secure but slower)

# Future Security Settings (not yet implemented)
# HTTPS_ONLY=true                   # Enforce HTTPS in production
# RATE_LIMIT_ENABLED=true           # Enable rate limiting on auth endpoints
# RATE_LIMIT_PER_MINUTE=60          # Max requests per minute per IP
