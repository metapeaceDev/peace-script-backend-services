# Use pytest-asyncio managed event loop (no custom event_loop)

import pytest_asyncio

@pytest_asyncio.fixture(scope="function")
async def test_db_client() -> AsyncGenerator[AsyncIOMotorClient, None]:
    """Initialize a test database client."""
    client = AsyncIOMotorClient(settings.MONGODB_URI)
    yield client
    client.close()

@pytest_asyncio.fixture(scope="function", autouse=True)
async def test_database(test_db_client: AsyncIOMotorClient):
    """Initialize the database and collections for testing."""
    db_name = f"{settings.MONGODB_DB}_test"
    await init_beanie(
        database=test_db_client[db_name],
        document_models=[DigitalMindModel, KammaLogEntry, TrainingLog],
    )
    yield
    await test_db_client.drop_database(db_name)

@pytest_asyncio.fixture(scope="function", autouse=True)
async def setup_test_data():
    """Set up test data for the tests, ensuring all collections are clean."""
    await KammaLogEntry.delete_all()
    await TrainingLog.delete_all()
    await DigitalMindModel.delete_all()
    
    test_model = DigitalMindModel(**MOCK_DMM)
    await test_model.insert()
    
    yield
    
    await KammaLogEntry.delete_all()
    await TrainingLog.delete_all()
    await DigitalMindModel.delete_all()

@pytest_asyncio.fixture(scope="function")
async def async_client() -> AsyncGenerator[AsyncClient, None]:
    """Create an async client for making API requests using ASGITransport."""
    transport = ASGITransport(app=app, lifespan="off")
    async with AsyncClient(transport=transport, base_url="http://test") as client:
        yield client
