# Jitta Assistant Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=Jitta
JITTA_ROOT_DIR=.
JITTA_DATA_DIR=./data
JITTA_ALLOW_SHELL_COMMANDS=false
JITTA_ALLOW_WEB_ACCESS=true

# Telegram Bot (required for telegram_bot.py)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# Fast Model (for quick responses)
FAST_LLM_BASE_URL=http://127.0.0.1:8001/v1
FAST_LLM_MODEL=qwen3.5-14b-instruct
FAST_LLM_API_KEY=

# Quality Model (for complex tasks)
QUALITY_LLM_BASE_URL=http://127.0.0.1:8002/v1
QUALITY_LLM_MODEL=qwen3.5-32b-instruct
QUALITY_LLM_API_KEY=

# RAG Settings
RAG_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBED_DEVICE=auto
RAG_TOP_K=4

# Development Settings
MOCK_LLM=false
